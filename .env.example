# Required: NVIDIA NIM API credentials
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Models — comma-separated fallback lists are supported
PRIMARY_MODEL=stepfun-ai/step-3.5-flash
AUDIT_MODEL=google/gemma-4-31b-it,google/gemma-3n-e2b-it,google/gemma-3n-e4b-it

# Optional: timeout and bounded retry policy for slow live Tier-2 probe requests
NIM_TIMEOUT_SECONDS=45
NIM_MAX_RETRIES=2

# Optional: response cache for Tier-2 probe runs
CACHE_DIR=.cache/nim_responses
